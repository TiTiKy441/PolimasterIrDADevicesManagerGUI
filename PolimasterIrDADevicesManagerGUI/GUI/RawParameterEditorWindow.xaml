<Window x:Class="PolimasterIrDADevicesManagerGUI.GUI.RawParameterEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PolimasterIrDADevicesManagerGUI.GUI"
        mc:Ignorable="d"
        Title="Raw parameter editor" Height="345" Width="301" ResizeMode="CanMinimize">
    <Grid>
        <Grid VerticalAlignment="Bottom" Height="30">
            <Button x:Name="discover_button" Content="Discover" FontSize="9" Margin="8,5,212,5" Click="discover_button_Click" />
            <Button x:Name="read_button" Content="Read all" FontSize="9" Margin="78,5,143,5" Click="read_button_Click" />
            <Button x:Name="write_button" Content="Write all" FontSize="9" Margin="147,5,73,5" Click="write_button_Click" />
            <Button x:Name="cancel_button" Content="Cancel" FontSize="9" Margin="217,5,6,5" Click="cancel_button_Click" />
        </Grid>
        <ListView Height="275" VerticalAlignment="Top" x:Name="values_table_listview" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="BorderBrush" Value="LightGray" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="addr" Width="50" DisplayMemberBinding="{Binding Address}"/>

                    <GridViewColumn Header="value" Width="150" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding BytesValueAsString, UpdateSourceTrigger=PropertyChanged}" 
                         BorderThickness="0" Background="Transparent" IsEnabled="{Binding Editable}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="uint16" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding UshortValue, UpdateSourceTrigger=PropertyChanged}" 
                         BorderThickness="0" Background="Transparent" IsEnabled="{Binding Editable}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="edit" Width="30">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Editable, UpdateSourceTrigger=PropertyChanged}" 
                         BorderThickness="0" Background="Transparent" IsEnabled="False"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
